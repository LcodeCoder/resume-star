# ============================================
# resume-lcode 生产环境变量配置示例
# 复制此文件为 .env 并修改真实值
# ============================================

# ---- AI 功能（可选，不配置则使用本地模拟响应） ----
# RESUME_AI_ENDPOINT=https://api.openai.com/v1/chat/completions
# RESUME_AI_API_KEY=sk-your-api-key
# RESUME_AI_MODEL=gpt-4
# RESUME_AI_TIMEOUT=15000

# ---- 邮件配置（可选） ----
# SPRING_MAIL_HOST=smtp.example.com
# SPRING_MAIL_PORT=587
# SPRING_MAIL_USERNAME=your-email@example.com
# SPRING_MAIL_PASSWORD=your-password

# ---- 数据库（默认使用 SQLite，无需配置） ----
# SPRING_DATASOURCE_URL=jdbc:sqlite:/app/data/resume-lcode.db

# ---- 数据库（MySQL 切换） ----
# SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/resume_lcode
# SPRING_DATASOURCE_USERNAME=root
# SPRING_DATASOURCE_PASSWORD=password

# ---- 跨域（生产部署请替换为真实域名） ----
# RESUME_CORS_ORIGINS=https://your-domain.com

# ---- Cookie 安全（生产 HTTPS 环境务必设为 true） ----
# SERVER_COOKIE_SECURE=true

# ---- 时区 ----
TZ=Asia/Shanghai