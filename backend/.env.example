# resume-lcode 后端环境变量样例
# 用法：复制为 .env 并填入真实值；生产用密钥管理/配置中心注入，切勿提交真实值到 git
# ------------------------------------------------------------------
# MySQL 连接（生产必填 MYSQL_PASSWORD，无默认值，缺失将启动失败）
MYSQL_HOST=149.88.72.233
MYSQL_PORT=3306
MYSQL_DB=resume-lcode
MYSQL_USER=resume-lcode
MYSQL_PASSWORD=

# 连接池（可按压测调整）
DB_POOL_MAX=10
DB_POOL_MIN=2

# 会话 Cookie：生产走 HTTPS 时置 true
SESSION_COOKIE_SECURE=false

# AI 网关（可选）
RESUME_AI_ENDPOINT=
RESUME_AI_API_KEY=
RESUME_AI_MODEL=resume-optimizer

# 邮件（可选）
RESUME_EMAIL_USERNAME=
RESUME_EMAIL_PASSWORD=

# ==================================================================
# 安全提醒：
# 1) 该 MySQL 账号为 @% (任意 IP 可连) + 公网地址，上线前务必配置安全组/IP 白名单
# 2) 建议将示例中的弱口令更换为强随机口令
# ==================================================================
